MINDMAP_MODEL=qwen2.5:14b
# Timeout một lần gọi LLM sinh mind map (giây), vòng invoke bọc ThreadPoolExecutor
MINDMAP_TIMEOUT_SEC=90
FAISS_BACKUP_KEEP=3

# Ollama chat model (Q&A / conversation) — chạy: ollama pull qwen3.5:9b
SLM_MODEL_CHAT=qwen3.5:9b
# Summarize & Memory Tree model (nặng hơn, chất lượng cao hơn)
SLM_MODEL_SUMMARY=qwen2.5:14b
# Backward-compatible alias (một số chỗ vẫn đọc SLM_MODEL)
SLM_MODEL=qwen3.5:9b
# Qwen/thinking: 0 = gửi think=false cho Ollama (tránh content rỗng khi stream); 1 = bật. Model reasoning-only để trống.
OLLAMA_REASONING=0
# Giới hạn token OUTPUT (Ollama num_predict). Quá thấp → cắt giữa chừng; 8192 cho bài dài.
LLM_MAX_TOKENS=8192

# Query timeouts (CPU có thể cần cao hơn)
AI_TIMEOUT_SEC=600
QUERY_JOB_TIMEOUT_SEC=900
GUNICORN_TIMEOUT=900

# --- Phase 2 (memvid_phase2_detail) ---
HYBRID_TOP_K=6
SESSION_TTL_HOURS=24
SSE_TIMEOUT_SEC=300
# Context window: giảm để LLM generate nhanh hơn mà vẫn đủ thông tin
CTX_MAX_CHARS=8000
CTX_MAX_CHUNKS=8
# Timeout riêng cho Memory Tree lookup (ms) — nếu vượt thì fallback FAISS
MEMORY_TREE_TIMEOUT_SEC=15
ENABLE_QUERY_CITATION_PROMPT=1
# Bật kiểm tra Pydantic cho mindmap nodes (id/parent/title)
MINDMAP_SCHEMA_STRICT=0
MINDMAP_MAX_NODES=200

