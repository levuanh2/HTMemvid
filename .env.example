# ============================================================
# MemVid — Docker Compose runtime configuration
# ============================================================
# Copy to .env for local runs:  Copy-Item .env.example .env
# Do NOT commit .env (it is .gitignored). Never put real secrets here.
# docker-compose.yml reads these as ${VAR:-default}; unset = safe default.
# ============================================================

# Docker Compose project
COMPOSE_PROJECT_NAME=memvid_auth_smoke
COMPOSE_PROFILES=worker

# Auth
AUTH_SECRET=change-me-in-local-env
AUTH_REQUIRE_SECRET=true
AUTH_TOKEN_TTL_SEC=604800
AUTH_PROTECT_APP_APIS=false
USERS_DB_PATH=/app/memory/users.sqlite

# Conversation
CONVERSATION_CONTEXT_ENABLED=true
CONVERSATIONS_DB_PATH=/app/memory/conversations.sqlite

# Queue / worker
QUEUE_ENABLED=true
QUEUE_DEPTH_MAX=20
RQ_JOB_TIMEOUT_SEC=1800
WORKER_CONCURRENCY=1
JOBS_DB_PATH=/app/memory/jobs.sqlite
LOG_DB_PATH=/app/memory/logs.sqlite

# Ollama / models
OLLAMA_HOST=http://host.docker.internal:11434
SLM_MODEL_CHAT=qwen2.5:7b-instruct
SLM_MODEL=qwen2.5:7b-instruct
MINDMAP_MODEL=qwen2.5:7b-instruct
SLM_MODEL_SUMMARY=qwen2.5:7b-instruct
OLLAMA_REASONING=0
LLM_MAX_TOKENS=8192
MAX_CONCURRENT_LLM_CALLS=1
LLM_QUEUE_WAIT_TIMEOUT_SECONDS=180
# PR#4 query-priority lanes (gateway): batch (summary/mindmap) chi duoc dung
# MAX_CONCURRENT_LLM_CALLS - LLM_RESERVED_QUERY_SLOTS slot; query ("answer")
# dung slot reserve. Mac dinh OFF = hanh vi cu. Bat thu o staging truoc.
LLM_PRIORITY_LANES_ENABLED=false
LLM_RESERVED_QUERY_SLOTS=1
# In-process cap khi khong co gateway (LLM_GATEWAY_ADDR unset). Mac dinh ON.
LLM_INPROCESS_CAP_ENABLED=1

# Summary / mindmap timeouts
SUMMARY_LLM_TIMEOUT_SEC=300
MINDMAP_LLM_TIMEOUT_SEC=300
SUMMARY_PARALLEL=2

# Retrieval / embeddings
EMBEDDING_MODEL_NAME=BAAI/bge-m3
LATE_CHUNKING=1
HYBRID_TOP_K=6
USE_LC_VECTOR_STORE=1
USE_LC_QA_CHAIN=1
USE_LC_ENSEMBLE=1
USE_LC_INGEST=1

# Cache
REDIS_URL=redis://redis:6379/0
CACHE_ENV=prod
SINGLE_FLIGHT_ENABLED=true
SINGLE_FLIGHT_LOCK_TTL_SECONDS=180
SINGLE_FLIGHT_WAIT_SECONDS=120
SINGLE_FLIGHT_POLL_INTERVAL_SECONDS=0.5
SEMANTIC_CACHE_ENABLED=true

# Rate limit
RATE_LIMIT_ENABLED=false
RATE_LIMIT_RPS=1
RATE_LIMIT_BURST=5
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_SCOPE=ip
RATE_LIMIT_REQUIRE_REDIS=false
ADMISSION_RETRY_AFTER_SECONDS=5
