# ============================================================
# MemVid Backend - Environment Variables
# ============================================================
# Sao chép file này thành .env:  cp .env.example .env
# KHÔNG commit .env thật vào git (đã được .gitignore).
# ============================================================

# ===== AI PROVIDERS =====
# API key Gemini (bật khi dùng Google AI Studio model)
GEMINI_API_KEY=
# API key Groq (bật khi dùng Groq cloud)
GROQ_API_KEY=
# Host Ollama local (mặc định chạy trên port 11434)
OLLAMA_HOST=http://localhost:11434

# ===== LLM MODELS =====
# Model Ollama dùng cho chat Q&A (conversation)
SLM_MODEL=qwen3.5:9b
# Alias backward-compatible (một số chỗ vẫn đọc SLM_MODEL)
SLM_MODEL=qwen3.5:9b
# Model Ollama dùng cho summarize & memory tree (nặng hơn, chất lượng cao)
SLM_MODEL_SUMMARY=qwen2.5:14b
# Model siêu nhẹ cho Intent Classification (phân loại ý định user)
SLM_MODEL_INTENT=gemma2:2b
# Model cho mindmap generation (mặc định dùng SLM_MODEL_SUMMARY nếu trống)
MINDMAP_MODEL=qwen2.5:14b

# ===== SUMMARY V2 (section-first, job async — docs/SUMMARY_V2_SPEC.md) =====
# Timeout mỗi LLM call của pipeline tóm tắt (giây). CPU chậm nên để 240 trong Docker.
SUMMARY_LLM_TIMEOUT_SEC=120
# Số section tóm tắt song song
SUMMARY_PARALLEL=2
# Model Gemini cho chat (khi GEMINI_API_KEY được set)
GEMINI_CHAT_MODEL=gemini-2.5-flash
# Model Groq cho chat (khi GROQ_API_KEY được set)
GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# ===== LLM SETTINGS =====
# Giới hạn token OUTPUT (Ollama num_predict). Quá thấp -> cắt giữa chừng
LLM_MAX_TOKENS=8192
# Temperature cho LLM (0.0 = deterministic, 1.0 = random)
# LLM_TEMPERATURE: chat hội thoại (văn phong tự nhiên).
# LLM_TEMPERATURE_FACTUAL: tác vụ factual/grounded (sinh đáp án RAG, summary,
#   grade, classify) → tiến 0 để bám sự thật + tái lập, giảm bịa đặt.
# Override per-call qua options['temperature'] luôn thắng (vd mindmap 0.1–0.2).
LLM_TEMPERATURE=0.3
LLM_TEMPERATURE_FACTUAL=0
# Context window size (num_ctx cho Ollama)
LLM_CTX_SIZE=4096
# Bật/tắt reasoning mode cho Qwen/thinking models (0=off, 1=on)
OLLAMA_REASONING=0
# Alias cho OLLAMA_REASONING (cùng ý nghĩa)
OLLAMA_THINK=
# Timeout một lần gọi LLM (giây)
AI_TIMEOUT_SEC=600

# ===== EMBEDDING =====
# Model embedding (BAAI/bge-m3: đa ngôn ngữ, dimension 1024)
# Nếu đổi model -> PHẢI rebuild FAISS index vì dimension thay đổi
# Fallback cũ: sentence-transformers/all-MiniLM-L6-v2 (dimension 384)
EMBEDDING_MODEL_NAME=BAAI/bge-m3
# Cache size cho query embedding vector (LRU, md5-based)
QUERY_EMBED_CACHE_MAX=512
# Kích thước batch khi embedding documents/queries
EMBED_BATCH_SIZE=64
# Bỏ qua load embedding model (CI/testing mode, dùng FakeEmbeddings)
SKIP_MODEL_LOAD=0
# Late chunking (MẶC ĐỊNH BẬT): embed token TOÀN VĂN rồi mean-pool theo ranh giới chunk
# → mỗi vector "thấm" ngữ cảnh toàn cục (giải bài toán tham chiếu ngược ở tài liệu dài).
# Query và chunk dùng CÙNG encoder mean-pool (bge-m3). Yêu cầu EMBEDDING_MODEL_NAME là
# long-context encoder (bge-m3 / jina-v3 / nomic) — KHÔNG dùng all-MiniLM (max 512 token).
# Đổi scheme này (bật/tắt) hay đổi model → PHẢI rebuild FAISS index (pooling/dim đổi).
# Đặt 0 để quay về đường embed cũ (pooling CLS) trong tình huống khẩn.
LATE_CHUNKING=1

# ===== DATA PATHS =====
# Thư mục gốc chứa data (mặc định: thư mục chứa BE/)
DATA_DIR=./BE

# ===== QUERY / RETRIEVAL =====
# Số lượng top-k kết quả hybrid retrieval
HYBRID_TOP_K=6
# Trọng số BM25 trong hybrid (0.0 - 1.0)
HYBRID_BM25_WEIGHT=0.4
# Trọng số FAISS trong hybrid (0.0 - 1.0)
HYBRID_FAISS_WEIGHT=0.6
# Dùng LangChain ensemble retrieval
USE_LC_ENSEMBLE=1
# Dùng LangChain QA chain
USE_LC_QA_CHAIN=1
# Dùng LangChain vector store
USE_LC_VECTOR_STORE=1
# Dùng LangChain ingest pipeline
USE_LC_INGEST=1
# Bật kiểm tra Pydantic cho mindmap nodes
MINDMAP_SCHEMA_STRICT=0
# Giới hạn số node tối đa trong mindmap
MINDMAP_MAX_NODES=200
# Timeout sinh mindmap (giây), vòng invoke bọc ThreadPoolExecutor
MINDMAP_TIMEOUT_SEC=240
# Timeout mindmap theo mode (giây). Default gốc; tăng nếu Ollama/CPU chậm.
#   LLM = mỗi lần gọi LLM; JOB = tổng thời gian cả job.
MINDMAP_LLM_TIMEOUT_FAST=60
MINDMAP_LLM_TIMEOUT_BALANCED=90
MINDMAP_LLM_TIMEOUT_QUALITY=120
MINDMAP_JOB_TIMEOUT_FAST=90
MINDMAP_JOB_TIMEOUT_BALANCED=180
MINDMAP_JOB_TIMEOUT_QUALITY=600
# Context window: giới hạn ký tự cho mỗi query
CTX_MAX_CHARS=8000
# Context window: giới hạn số chunks cho mỗi query
CTX_MAX_CHUNKS=8
# Timeout riêng cho Memory Tree lookup (giây)
MEMORY_TREE_TIMEOUT_SEC=30

# ===== CRAG / SUPERVISOR / HITL (mặc định tắt → graph chạy như cũ) =====
# Corrective RAG: chấm điểm chunk → correct=trả lời / ambiguous=viết lại / wrong=viết lại rồi báo không tìm thấy
CRAG_ENABLED=0
# Ngưỡng "correct" (best relevance >= ngưỡng → correct)
CRAG_RELEVANCE_THRESHOLD=0.25
# Sàn "wrong" (best relevance <= sàn → wrong)
CRAG_WRONG_FLOOR=0.1
# Số lần viết lại câu hỏi tối đa trước khi fallback
CRAG_REWRITE_MAX=1
# Supervisor router: phân loại câu hỏi → định tuyến memory/retrieval
SUPERVISOR_ENABLED=0
# Human-in-the-loop: tạm dừng chờ duyệt câu trả lời (cần checkpointer); resume qua POST /query-resume/<job_id>
HITL_ENABLED=0

# ===== RERANK (Two-Stage Retrieval — mặc định tắt → graph chạy như cũ) =====
# Stage 1 lấy RERANK_CANDIDATE_K ứng viên (rộng); Stage 2 cross-encoder lọc xuống RERANK_TOP_N.
RERANK_ENABLED=0
# Backend: cross_encoder (self-host, offline) | cohere (cần COHERE_API_KEY) | llm | none
RERANK_BACKEND=cross_encoder
# Model cross-encoder. bge-reranker-v2-m3: tốt tiếng Việt, ctx 8K (~568M, lần đầu tải ~2GB).
# Nhẹ hơn: BAAI/bge-reranker-base | cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_MODEL=BAAI/bge-reranker-v2-m3
# Số ứng viên Stage 1 (recall). Nên >= HYBRID_TOP_K.
RERANK_CANDIDATE_K=20
# Số chunk giữ lại sau rerank (0 => dùng HYBRID_TOP_K).
RERANK_TOP_N=0
# Batch size khi cross-encoder chấm điểm cặp (query, passage).
RERANK_BATCH=16
# Timeout (giây) cho bước rerank — quá hạn thì giữ nguyên thứ tự, cắt top_n.
RERANK_TIMEOUT_SEC=10
# COHERE_API_KEY=...   # chỉ khi RERANK_BACKEND=cohere

# ===== NLI / CONTRADICTION-CHECK (mặc định tắt → graph chạy như cũ) =====
# Node VerifyContext: quét các cặp chunk top-K bằng mDeBERTa, loại chunk hạng thấp
# khi MÂU THUẪN với chunk hạng cao (bắt điểm mù embedding: phủ định/đổi thực thể/
# thời gian/con số — vd "12 ngày" vs "20 ngày", "được nghỉ" vs "không được nghỉ").
# Chạy SAU Rerank nếu cả hai cùng bật. Mọi lỗi/timeout → giữ nguyên context.
NLI_ENABLED=0
# Model NLI đa ngôn ngữ (lần đầu tải ~560MB; chạy CPU; cần sentencepiece).
NLI_MODEL=MoritzLaurer/mDeBERTa-v3-base-mnli-xnli
# prob 'contradiction' tối thiểu để tính một cặp là xung đột (0.0 - 1.0).
NLI_CONTRADICTION_THRESHOLD=0.6
# Timeout (giây) cho bước NLI — quá hạn thì giữ nguyên context.
# Đo thực CPU: 3 cặp chunk dài ≈ 66s → để 90s; có GPU thì hạ xuống.
NLI_TIMEOUT_SEC=90
# Trần số cặp chunk đem đi NLI (kiểm soát latency; ưu tiên các chunk hạng cao).
# Mỗi cặp ~14s trên CPU → giữ nhỏ; tăng khi có GPU.
NLI_MAX_PAIRS=3

# ===== CITATION =====
# Bật prompt citation cho query (thêm hướng dẫn trích nguồn cho LLM)
ENABLE_QUERY_CITATION_PROMPT=1
# Nội dung suffix thêm vào system prompt cho citation
QUERY_CITATION_SYSTEM_SUFFIX=

# ===== CHUNKING =====
# Kích thước chunk khi chia document (số ký tự)
CHUNK_SIZE=500
# Độ chồng lấn giữa các chunk liền kề (số ký tự)
CHUNK_OVERLAP=50

# ===== SESSION & CACHE =====
# TTL cho session data (giờ)
SESSION_TTL_HOURS=24
# Giới hạn messages tối đa trong một session
SESSION_MAX_MESSAGES=80
# Cache size cho query results (LRU)
QUERY_CACHE_MAX_SIZE=200
# TTL cho query cache (giây)
CACHE_TTL_SEC=1800

# --- Cache Redis 3 tầng (semantic + retrieval) ---
# Fail-open: Redis chết hoặc REDIS_URL rỗng → app chạy bình thường, cache tự tắt.
# Mọi ingest/delete tài liệu tự vô hiệu cache qua index_version (mtime index.json).
# Spec chi tiết: docs/SEMANTIC_CACHE_SPEC.md
# Master switch mọi tầng cache Redis (1=on, 0=off)
CACHE_ENABLED=1
# Rỗng = cache Redis tắt im lặng (dev Windows không cần Redis); docker-compose set redis://redis:6379/0
REDIS_URL=
# Tier 2: cache câu trả lời theo ngữ nghĩa (cosine bge-m3)
SEMANTIC_CACHE_ENABLED=1
# Tier 3: cache kết quả retrieve FAISS/BM25
RETRIEVAL_CACHE_ENABLED=1
# TTL semantic cache (giây) — 48h, answer từ tài liệu đã ingest
SEMANTIC_CACHE_TTL_SECONDS=172800
# Ngưỡng cosine để trả answer cũ; sàn 0.80 (dưới sàn bị clamp + warning)
SEMANTIC_CACHE_THRESHOLD=0.85
# 1 = cho phép threshold <0.80 (nguy cơ cache poisoning — chỉ dùng khi hiểu rõ)
SEMANTIC_CACHE_THRESHOLD_FLOOR_OVERRIDE=0
# LLM judge gác vùng borderline [0.80, 0.88): sim ≥0.88 hit thẳng, sim trong band phải
# được judge duyệt (same intent + safe) mới hit. Tắt (0) = rule threshold thuần như cũ.
SEMANTIC_CACHE_JUDGE_ENABLED=1
SEMANTIC_CACHE_JUDGE_TIMEOUT_SEC=15
# Ước lượng $ tiết kiệm mỗi hit (0 = không tính) — hiện trong /stats.estimated_cost_saved_usd
SEMANTIC_CACHE_COST_PER_CALL_USD=0
# TTL retrieval cache (giây) — 1h
RETRIEVAL_CACHE_TTL_SECONDS=3600
# Prefix key Redis (tách project/app)
CACHE_NAMESPACE=memvid
# dev/prod — tách key giữa môi trường
CACHE_ENV=dev

# ===== JOB / WORKER =====
# TTL cho job (phút)
JOB_TTL_MINUTES=30
# TTL cho query job (phút)
QUERY_JOB_TTL_MINUTES=30
# Timeout cho query job (giây)
QUERY_JOB_TIMEOUT_SEC=900
# Số query đồng thời tối đa (admission cap per gunicorn worker, KHÔNG phải global)
QUERY_MAX_CONCURRENT=4

# ===== BACKGROUND JOB QUEUE — RQ (Phase 5, Step 1: ingest only) =====
# Bật RQ worker cho heavy jobs (ingest). MẶC ĐỊNH TẮT — flag off = daemon-thread như cũ.
# Fail-safe: enqueue lỗi/Redis chết → rơi về thread, upload vẫn chạy.
QUEUE_ENABLED=false
# Số job đồng thời mỗi worker. CPU serial → để 1 (2 job nặng = thrash như Phase 1).
WORKER_CONCURRENCY=1
# Ngưỡng queue depth: /ready trả 503 (reason=queue_full) khi vượt (chỉ khi QUEUE_ENABLED).
QUEUE_DEPTH_MAX=20
# Timeout mỗi RQ job (giây) — ingest/summary/mindmap dài, để rộng.
RQ_JOB_TIMEOUT_SEC=1800
# CHIA SẺ DB giữa web + worker: PHẢI trỏ vào volume mount chung (/app/memory) để FE thấy
# trạng thái job worker. Bỏ trống = đường DATA_DIR cũ (dev/test 1-process).
JOBS_DB_PATH=/app/memory/jobs.sqlite
LOG_DB_PATH=/app/memory/logs.sqlite

# ===== INGRESS OVERLOAD PROTECTION (Phase 4 — app/main.py) =====
# Rate limit /query (Redis token-bucket). MẶC ĐỊNH TẮT ở local — bật rõ ràng cho prod.
# Fail-open: Redis chết → cho qua (trừ khi RATE_LIMIT_REQUIRE_REDIS=true). KHÔNG áp cho /health.
RATE_LIMIT_ENABLED=false
# Token refill (request/giây) và burst (số token tối đa) mỗi scope.
RATE_LIMIT_RPS=1
RATE_LIMIT_BURST=5
# TTL của bucket key (giây) — key tự dọn sau khi client ngừng gọi.
RATE_LIMIT_WINDOW_SECONDS=60
# scope=ip (mặc định) hoặc session/user (dùng session_id nếu có).
RATE_LIMIT_SCOPE=ip
# true = Redis chết thì TỪ CHỐI (prod nghiêm ngặt); false = fail-open (local/dev).
RATE_LIMIT_REQUIRE_REDIS=false
# Retry-After (giây) cho 429 khi admission semaphore đầy.
ADMISSION_RETRY_AFTER_SECONDS=5

# ===== SINGLE-FLIGHT / REQUEST COALESCING (Phase 3, DR-3 D3 — app/main.py::query) =====
# Gộp các request trùng/tương đương đồng thời: 1 leader chạy RAG/LLM + ghi cache, các
# follower chờ ngắn rồi đọc cache. Optimization-only, fail-open (Redis chết → chạy bình thường).
SINGLE_FLIGHT_ENABLED=true
# TTL của Redis lock (giây) — leader chết thì lock tự hết hạn, không kẹt vĩnh viễn.
SINGLE_FLIGHT_LOCK_TTL_SECONDS=180
# Follower chờ tối đa (giây) leader ghi cache; quá hạn → fail-open chạy đường riêng.
SINGLE_FLIGHT_WAIT_SECONDS=120
# Khoảng poll cache của follower (giây).
SINGLE_FLIGHT_POLL_INTERVAL_SECONDS=0.5

# ===== LLM GATEWAY GLOBAL CAP (Phase 2, DR-3 D2 — services/llm_gateway/server.py) =====
# Số generation LLM chạy ĐỒNG THỜI tối đa trong tiến trình gateway (chokepoint duy nhất
# về 1 Ollama CPU). CPU: 1–2. Đây là throttle THẬT (khác QUERY_MAX_CONCURRENT per-worker).
MAX_CONCURRENT_LLM_CALLS=2
# Thời gian chờ tối đa (giây) khi mọi slot đang bận; quá hạn → lỗi busy có kiểm soát
# (RESOURCE_EXHAUSTED) → job error, KHÔNG bao giờ trả rỗng, KHÔNG treo vô hạn.
LLM_QUEUE_WAIT_TIMEOUT_SECONDS=30
# TTL cho mindmap job (phút)
MINDMAP_JOB_TTL_MINUTES=30
# Dùng SQLite jobs thay vì in-memory (1=on, 0=off)
USE_SQLITE_JOBS=1
# Số backup FAISS index giữ lại
FAISS_BACKUP_KEEP=3
# Số workers cho summarize đồng thời
MAX_SUMMARIZE_WORKERS=3

# ===== SERVER / CORS =====
# CORS origins (comma-separated, * = all)
CORS_ORIGINS=*
# Port chạy backend
PORT=8080
# Timeout cho SSE stream (giây)
SSE_TIMEOUT_SEC=300
# Poll interval cho SSE status (giây)
SSE_POLL_INTERVAL_SEC=0.4
# Warmup Ollama khi start server (1=on, 0=off)
OLLAMA_WARMUP=1

# ===== DEBUG / CI =====
# Debug mode (1=on, 0=off)
DEBUG=0
# Bỏ qua load dotenv file (CI mode)
SKIP_DOTENV=0
# Tắt default LangChain settings
MEMVID_DISABLE_LC_DEFAULTS=0
# Chạy load test (1=on, 0=off)
RUN_LOAD_TEST=0
# URL base cho load test
BASE_URL=http://localhost:8080
# Bật đánh giá query (true/false)
EVAL_ENABLED=false
# Ngưỡng đánh giá query
EVAL_THRESHOLD=0.6
# Timeout AI trong query graph (giây)
AI_TIMEOUT_SEC=180
# Thêm tags chunk source vào response
INCLUDE_CHUNK_SOURCE_TAGS=0
# Gunicorn timeout (giây)
GUNICORN_TIMEOUT=900
